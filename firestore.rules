rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == 'gamingboylive46@gmail.com' && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read any profile (for reviews) but only write their own
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email'])) || isAdmin();
    }

    match /settings/{settingId} {
      // Only admin can read/write global settings
      allow read, write: if isAdmin();
    }

    match /apps/{appId} {
      // Anyone can see published apps, admin sees all, owners see their own
      allow read: if resource.data.status == 'published' || isAdmin() || (isAuthenticated() && resource.data.uploadedBy == request.auth.uid);
      
      // Any authenticated user can submit an app
      allow create: if isAuthenticated() && 
        request.resource.data.status == (isAdmin() ? 'published' : 'pending') &&
        request.resource.data.uploadedBy == request.auth.uid;
        
      // Only admin can approve, update or delete apps
      allow update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      // Reviews are public
      allow read: if true;
      
      // Authenticated users can post reviews
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
        
      // Only owner or admin can delete reviews
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
  }
}
